# Copy to .env.local for local runs. Never commit real secrets.

# --- Rank Politician: Firecrawl scrape ---
FIRECRAWL_API_KEY=

# --- Rank Politician: LLM classification (LiteLLM-compatible) ---
# Preferred: AWS Bedrock API key (bearer token) for Kimi K2.5
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION_NAME=us-east-1
LLM_MODEL=moonshotai.kimi-k2.5

# Optional: route through a LiteLLM proxy instead of Bedrock Mantle directly
# LITELLM_BASE_URL=http://localhost:4000
# LITELLM_API_KEY=sk-...

# Optional overrides
# BEDROCK_MANTLE_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/v1
# LLM_TIMEOUT_MS=45000

# --- App ---
MONGODB_URI=
CRON_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
